# Espelha as credenciais de docker/.env (POSTGRES_USER / POSTGRES_PASSWORD)
DB_USER=changeme
DB_PASSWORD=changeme

# Acesso via túnel SSH (Postgres só existe em 127.0.0.1 na VPS - ver docs/security.md)
DB_HOST=localhost
DB_PORT=5434

# Banco onde os schemas dos drills SQL vivem (não é o POSTGRES_DB do docker/.env, que é o banco de manutenção)
DB_NAME=estudos